rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //
    // Collection: /requests/{requestId}
    // Fields:
    //   - userId: string (required)
    //   - buildingName: string (required)
    //   - apartmentNumber: string (required)
    //   - serviceType: string (required)
    //   - date: timestamp (required)
    //   - monthsCount: number (required)
    //   - price: number (required)
    //   - status: string (required, ['pending', 'in-progress', 'completed'])
    //   - paymentStatus: string (required, ['unpaid', 'paid'])
    //   - notes: string (optional)
    //   - receiptUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "11aabbcc54@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 150;
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['userId', 'buildingName', 'apartmentNumber', 'serviceType', 'date', 'monthsCount', 'price', 'status', 'paymentStatus', 'createdAt']) &&
             data.userId is string &&
             data.buildingName is string && data.buildingName.size() < 100 &&
             data.apartmentNumber is string && data.apartmentNumber.size() < 100 &&
             data.serviceType is string &&
             data.date is timestamp &&
             data.monthsCount is number &&
             data.price is number && data.price >= 0 &&
             data.status in ['pending', 'in-progress', 'completed'] &&
             data.paymentStatus in ['unpaid', 'paid'] &&
             (!('receiptUrl' in data) || data.receiptUrl is string) &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin()) && isValidRequest(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidRequest(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
